# 텔레그램 봇 설정
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 키움 API 설정
KIWOOM_HOST=https://api.kiwoom.com
KIWOOM_APPKEY=your_kiwoom_appkey_here
KIWOOM_SECRETKEY=your_kiwoom_secretkey_here

# 키움 계좌 정보
KIWOOM_ACCOUNT_NO=your_account_number
KIWOOM_ACCOUNT_PRODUCT_CD=01
KIWOOM_ACCOUNT_PW=your_account_password
KIWOOM_MEDIA_TYPE=00

# WebSocket (선택)
KIWOOM_WS_HOST=wss://api.kiwoom.com:10000/api/dostk/websocket

# 거래 모드
TRADE_MODE=real  # real or mock

# OpenAI API (선택 - 사용하지 않으면 비워두세요)
OPENAI_API_KEY=

# 테스트 설정 (선택)
# TEST_LAST_PRICE=116000  # 테스트용 고정 가격
# IGNORE_MARKET_HOURS=1   # 장외 시간에도 작동

# 로깅 레벨
LOG_LEVEL=INFO

# 가격 모니터링 간격 (초)
MONITOR_INTERVAL=10

# 웹 서버 설정
WEB_PORT=5000
WEB_HOST=0.0.0.0

# Order Settings
ORDER_SIMULATION_MODE=1  # 1=시뮬레이션, 0=실제주문 (주의!)
KIWOOM_DEBUG=0           # 1=디버그모드
